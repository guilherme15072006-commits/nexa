# =====================================================
# NEXA — Environment Variables
# Copie para .env e preencha os valores
# NUNCA commite o arquivo .env
# =====================================================

# --- Amplitude (Analytics) ---
AMPLITUDE_API_KEY=

# --- Linear (Gestao de Tarefas) ---
LINEAR_API_KEY=lin_api_
LINEAR_TEAM_ID=
LINEAR_PROJECT_ID=
LINEAR_LABEL_BUG=
LINEAR_LABEL_FEATURE=
LINEAR_LABEL_UX=
LINEAR_LABEL_PERFORMANCE=
LINEAR_LABEL_ANALYTICS=
LINEAR_LABEL_BETTING=
LINEAR_LABEL_GAMIFICATION=
LINEAR_LABEL_RESPONSIBLE=

# --- Cloudflare (API Edge) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Vercel (Deploy Site) ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- NEXA API ---
NEXA_API_URL=https://api.nexa.bet
NEXA_CDN_URL=https://cdn.nexa.bet
NEXA_WS_URL=wss://ws.nexa.bet
